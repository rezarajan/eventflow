{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rezarajan/eventflow/contracts/eventflow-registry.v2.schema.json",
  "title": "Eventflow Registry v2",
  "type": "object",
  "required": ["version", "events"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": "eventflow.registry.v2" },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/event" }
    }
  },
  "$defs": {
    "event": {
      "type": "object",
      "required": ["kind", "payload_schema", "channel"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "type": { "type": "string" },
        "envelope": { "$ref": "#/$defs/envelope" },
        "payload_schema": { "type": "string", "minLength": 1 },
        "schema": { "type": "string" },
        "channel": { "$ref": "#/$defs/channel" },
        "adapter": { "$ref": "#/$defs/adapter" },
        "validation": { "$ref": "#/$defs/validation" },
        "source": { "$ref": "#/$defs/source" },
        "required_extensions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "asyncapi_ref": { "type": "string" },
        "openapi_ref": { "type": "string" },
        "projection": { "$ref": "#/$defs/projection" },
        "storage": { "$ref": "#/$defs/storage" },
        "metadata": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "envelope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string" },
        "source": { "type": "string" },
        "source_regex": { "type": "string" },
        "subject": { "type": "string" },
        "datacontenttype": { "type": "string" },
        "extensions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "channel": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "protocol": { "type": "string" },
        "topic": { "type": "string" },
        "path": { "type": "string" },
        "ref": { "type": "string" }
      }
    },
    "adapter": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "codec": {
          "enum": ["cloudevents-json", "cloudevents-binary-http", "openlineage-json", "ndjson", "json"]
        },
        "config": { "type": "object" }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["strict", "compatible", "permissive", "disabled"] },
        "custom_validators": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow": {
          "type": "array",
          "items": { "type": "string" }
        },
        "regex": { "type": "string" },
        "require_uri": { "type": "boolean" }
      }
    },
    "projection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "table": { "type": "string" },
        "mode": { "type": "string" }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string" },
        "bucket": { "type": "string" },
        "prefix": { "type": "string" },
        "table": { "type": "string" }
      }
    }
  }
}


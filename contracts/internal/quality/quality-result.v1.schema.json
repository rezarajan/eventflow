{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:eventflow:schemas:quality-result:v1",
  "title": "Quality Result V1",
  "type": "object",
  "required": [
    "run_id",
    "rule_id",
    "dataset",
    "status",
    "evaluated_at"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "format": "uuid"
    },
    "rule_id": {
      "type": "string"
    },
    "dataset": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "warn"
      ]
    },
    "observed_value": {
      "type": [
        "number",
        "string",
        "boolean",
        "null"
      ]
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}

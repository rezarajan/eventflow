{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:eventflow:schemas:quality-rule:v1",
  "title": "Quality Rule V1",
  "type": "object",
  "required": [
    "rule_id",
    "dataset",
    "dimension",
    "severity",
    "expression"
  ],
  "properties": {
    "rule_id": {
      "type": "string"
    },
    "dataset": {
      "type": "string"
    },
    "dimension": {
      "type": "string",
      "enum": [
        "completeness",
        "validity",
        "consistency",
        "uniqueness",
        "timeliness",
        "referential_integrity"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warn",
        "error"
      ]
    },
    "expression": {
      "type": "string"
    }
  },
  "additionalProperties": false
}

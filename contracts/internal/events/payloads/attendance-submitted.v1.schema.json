{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:datascape:schemas:attendance-submitted:v1",
  "title": "Attendance Submitted",
  "type": "object",
  "required": [
    "attendance_id",
    "student_id",
    "class_id",
    "school_id",
    "attendance_date",
    "status_code",
    "submitted_at"
  ],
  "properties": {
    "attendance_id": {
      "type": "string",
      "format": "uuid"
    },
    "student_id": {
      "type": "string",
      "format": "uuid"
    },
    "class_id": {
      "type": "string",
      "format": "uuid"
    },
    "school_id": {
      "type": "string",
      "format": "uuid"
    },
    "attendance_date": {
      "type": "string",
      "format": "date"
    },
    "status_code": {
      "type": "string",
      "enum": [
        "PRESENT",
        "ABSENT",
        "LATE",
        "EXCUSED"
      ]
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:datascape:schemas:document-checksummed:v1",
  "title": "Document Checksummed",
  "type": "object",
  "required": [
    "document_upload_id",
    "object_uri",
    "checksum_sha256",
    "checked_at"
  ],
  "properties": {
    "document_upload_id": {
      "type": "string",
      "format": "uuid"
    },
    "object_uri": {
      "type": "string"
    },
    "checksum_sha256": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}

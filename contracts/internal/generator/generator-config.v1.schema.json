{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:eventflow:schemas:generator-config:v1",
  "title": "Generator Config V1",
  "type": "object",
  "required": [
    "seed",
    "country",
    "academic_year",
    "district_count",
    "school_count",
    "students_per_school",
    "attendance_start_date",
    "attendance_end_date",
    "pdf_generation_enabled"
  ],
  "properties": {
    "seed": {
      "type": "integer",
      "minimum": 0
    },
    "country": {
      "type": "string"
    },
    "academic_year": {
      "type": "string"
    },
    "district_count": {
      "type": "integer",
      "minimum": 1
    },
    "school_count": {
      "type": "integer",
      "minimum": 1
    },
    "students_per_school": {
      "type": "integer",
      "minimum": 1
    },
    "attendance_start_date": {
      "type": "string",
      "format": "date"
    },
    "attendance_end_date": {
      "type": "string",
      "format": "date"
    },
    "pdf_generation_enabled": {
      "type": "boolean"
    },
    "output_targets": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "postgres",
          "s3",
          "events"
        ]
      }
    }
  },
  "additionalProperties": false
}

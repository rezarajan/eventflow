{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:eventflow:schemas:registry:v1",
  "title": "Eventflow Registry",
  "type": "object",
  "required": ["version", "events"],
  "properties": {
    "version": {
      "const": "eventflow.registry.v1"
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "schema", "channel"],
        "properties": {
          "type": {"type": "string", "minLength": 1},
          "schema": {"type": "string", "minLength": 1},
          "channel": {"type": "string", "minLength": 1},
          "projection": {
            "type": "object",
            "properties": {
              "table": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:eventflow:schemas:component-register:v1",
  "title": "Component Register V1",
  "type": "object",
  "required": [
    "components"
  ],
  "properties": {
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "component_id",
          "name",
          "boundary",
          "standard_or_port"
        ],
        "properties": {
          "component_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "boundary": {
            "type": "string",
            "enum": [
              "external_standard",
              "internal_port",
              "adapter",
              "service",
              "storage"
            ]
          },
          "standard_or_port": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:datascape:schemas:undercurrent-scorecard:v1",
  "title": "Undercurrent Scorecard V1",
  "type": "object",
  "required": [
    "component_id",
    "scores"
  ],
  "properties": {
    "component_id": {
      "type": "string"
    },
    "scores": {
      "type": "object",
      "required": [
        "security",
        "data_management",
        "dataops",
        "architecture",
        "orchestration",
        "software_engineering"
      ],
      "properties": {
        "security": {
          "type": "string",
          "enum": [
            "PASS",
            "PARTIAL",
            "DEFERRED",
            "FAIL"
          ]
        },
        "data_management": {
          "type": "string",
          "enum": [
            "PASS",
            "PARTIAL",
            "DEFERRED",
            "FAIL"
          ]
        },
        "dataops": {
          "type": "string",
          "enum": [
            "PASS",
            "PARTIAL",
            "DEFERRED",
            "FAIL"
          ]
        },
        "architecture": {
          "type": "string",
          "enum": [
            "PASS",
            "PARTIAL",
            "DEFERRED",
            "FAIL"
          ]
        },
        "orchestration": {
          "type": "string",
          "enum": [
            "PASS",
            "PARTIAL",
            "DEFERRED",
            "FAIL"
          ]
        },
        "software_engineering": {
          "type": "string",
          "enum": [
            "PASS",
            "PARTIAL",
            "DEFERRED",
            "FAIL"
          ]
        }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}

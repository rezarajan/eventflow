DATASCAPE_REDPANDA_TOPIC_MODE=single
DATASCAPE_REDPANDA_BATCH_SIZE=100
DATASCAPE_SEED=42
DATASCAPE_REDPANDA_CONSUMER_GROUP=datascape-consume-demo

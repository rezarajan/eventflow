EVENTFLOW_CONFIG=examples/school/eventflow.yaml
EVENTFLOW_REDPANDA_BROKERS=localhost:19092
EVENTFLOW_REDPANDA_TOPIC=school.events.v1
EVENTFLOW_REDPANDA_TOPIC_MODE=single
EVENTFLOW_REDPANDA_BATCH_SIZE=100
EVENTFLOW_REDPANDA_CONSUMER_GROUP=eventflow
EVENTFLOW_REDPANDA_CONSUMER_START_OFFSET=first
EVENTFLOW_DUCKDB_PATH=var/eventflow/eventflow.duckdb
EVENTFLOW_LINEAGE_OUTPUT=noop
EVENTFLOW_LINEAGE_FILE=var/eventflow/lineage/openlineage.ndjson
EVENTFLOW_LINEAGE_NAMESPACE=eventflow
EVENTFLOW_LINEAGE_PRODUCER=github.com/rezarajan/eventflow
EVENTFLOW_LINEAGE_SCHEMA_URL=https://openlineage.io/spec/1-0-5/OpenLineage.json
EVENTFLOW_LINEAGE_REPLAY_LIMIT=0
EVENTFLOW_MARQUEZ_URL=http://localhost:5000
EVENTFLOW_MARQUEZ_TIMEOUT=10s
